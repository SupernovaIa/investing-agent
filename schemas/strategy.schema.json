{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/javi/investing-agent/schemas/strategy.schema.json",
  "title": "Strategy",
  "description": "Investment strategy framework definition",
  "type": "object",
  "required": ["metadata", "sub_strategies", "global_rules"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["name", "version", "language"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "integer", "minimum": 1 },
        "language": { "type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$" },
        "description": { "type": "string" }
      }
    },

    "sub_strategies": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/SubStrategy" }
    },

    "global_rules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_active_positions": { "type": "integer", "minimum": 1 },
        "max_per_sub_strategy": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "opportunity_cash_reserve_eur": {
          "type": "object",
          "properties": {
            "target_min": { "type": "number", "minimum": 0 },
            "target_max": { "type": "number", "minimum": 0 },
            "location": { "type": "string" }
          }
        },
        "emergency_fund_eur": {
          "type": "object",
          "properties": {
            "amount": { "type": "number", "minimum": 0 },
            "location": { "type": "string" },
            "rule": { "type": "string" }
          }
        },
        "sector_concentration_max_pct": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },

    "playbooks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "success": {
          "type": "array",
          "items": { "$ref": "#/definitions/Playbook" }
        },
        "cautionary": {
          "type": "array",
          "items": { "$ref": "#/definitions/Playbook" }
        }
      }
    },

    "crash_plan": {
      "type": "object",
      "required": ["benchmark", "ladder"],
      "additionalProperties": false,
      "properties": {
        "benchmark": { "type": "string" },
        "reserve_location": { "type": "string" },
        "ladder": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/CrashStep" }
        }
      }
    },

    "crypto_plan": { "$ref": "#/definitions/CryptoPlan" },

    "analysis_style": { "$ref": "#/definitions/AnalysisStyle" }
  },

  "definitions": {

    "SubStrategy": {
      "type": "object",
      "required": ["id", "name", "type", "enabled"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["passive_dca", "discretionary", "dca_with_triggers", "lottery"]
        },
        "enabled": { "type": "boolean" },
        "dca_monthly_eur": { "type": "number", "minimum": 0 },
        "target_allocation": { "type": "string" },
        "horizon_years": { "type": "integer", "minimum": 1 },
        "rules": { "type": "array", "items": { "type": "string" } },
        "entry_criteria": {
          "type": "object",
          "properties": {
            "drawdown_from_ath_min": { "type": "number", "minimum": 0, "maximum": 100 },
            "drawdown_from_ath_max": { "type": "number", "minimum": 0, "maximum": 100 },
            "fundamentals": { "type": "string" },
            "quality_tier": { "type": "string" },
            "market_sentiment": { "type": "string" },
            "catalyst_required": { "type": "boolean" }
          }
        },
        "position_sizing": {
          "type": "object",
          "properties": {
            "typical_eur": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2
            },
            "max_eur": { "type": "number", "minimum": 0 },
            "scales_with": { "type": "string" }
          }
        },
        "max_positions": { "type": "integer", "minimum": 0 },
        "exit_criteria": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["condition", "action"],
            "properties": {
              "condition": { "type": "string" },
              "action": { "type": "string" },
              "threshold_pct": { "type": "number" }
            }
          }
        },
        "max_total_exposure_eur": { "type": "number", "minimum": 0 },
        "notes": { "type": "string" }
      }
    },

    "Playbook": {
      "type": "object",
      "required": ["ticker", "lesson"],
      "additionalProperties": false,
      "properties": {
        "ticker": { "type": "string" },
        "year": { "type": "integer" },
        "lesson": { "type": "string" }
      }
    },

    "CrashStep": {
      "type": "object",
      "required": ["drawdown_pct", "action"],
      "additionalProperties": false,
      "properties": {
        "drawdown_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "action": {
          "type": "string",
          "enum": ["deploy_eur", "deploy_remaining", "deploy_pct"]
        },
        "amount": { "type": "number", "minimum": 0 },
        "pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "target": { "type": "string" },
        "notes": { "type": "string" }
      }
    },

    "CryptoPlan": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dca_monthly_eur": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 }
        },
        "cashback_to": { "type": "string" },
        "cashback_estimate_monthly_eur": { "type": "number", "minimum": 0 },
        "hodl_only": { "type": "array", "items": { "type": "string" } },
        "reserve_for_crashes_eur": { "type": "number", "minimum": 0 },
        "crash_triggers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["asset", "condition", "threshold", "deploy_eur"],
            "properties": {
              "asset": { "type": "string" },
              "condition": { "type": "string" },
              "threshold": { "type": "number" },
              "currency": { "type": "string" },
              "deploy_eur": { "type": "number", "minimum": 0 }
            }
          }
        },
        "passive_lottery": { "type": "array", "items": { "type": "string" } },
        "rules": { "type": "array", "items": { "type": "string" } }
      }
    },

    "AnalysisStyle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tone": { "type": "string" },
        "formality": { "type": "string" },
        "language": { "type": "string" },
        "always_include": { "type": "array", "items": { "type": "string" } },
        "reference_playbooks": { "type": "boolean" },
        "red_flags_to_call_out": { "type": "array", "items": { "type": "string" } },
        "preferences": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
